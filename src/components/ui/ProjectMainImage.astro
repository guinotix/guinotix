---
import type { Project } from '@/types/project';

interface Props {
    project: Project;
}

const { project } = Astro.props;

const src = project.logo || project.img;

const imageClass = project.logo
    ? "rounded-2xl w-3/4 h-3/4 sm:w-1/2 sm:h-1/2 md:w-1/3 md:h-1/3"
    : "rounded-2xl w-5/6 h-5/6 sm:w-2/3 sm:h-2/3 md:w-1/2 md:h-1/2";
---

{ src &&
    <img class={imageClass}
        src={src}
        alt={project.alt}
    >
}
